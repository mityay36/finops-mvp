# НЕ КОММИТИТЬ! Создать вручную:
# kubectl create secret generic finops-api-secrets -n finops \
#   --from-literal=YC_ACCESS_KEY=<key> \
#   --from-literal=YC_SECRET_KEY=<secret>
apiVersion: v1
kind: Secret
metadata:
  name: finops-api-secrets
  namespace: finops
type: Opaque
stringData:
  YC_ACCESS_KEY: "YOUR_ACCESS_KEY"
  YC_SECRET_KEY: "YOUR_SECRET_KEY"
